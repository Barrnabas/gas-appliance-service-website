---
import Layout from '../layouts/layout.astro';
import { useTranslations } from '../i18n/utils';
import InteractiveMap from '../components/interactiveMap.astro';
import { Icon } from 'astro-icon/components';

const t = useTranslations();

const brands = ["Vaillant", "Saunier Duval", "Bosch", "Ariston", "Baxi", "Fég", "Westen"];

const locations = {
    pestCounty: [
        "Sülysáp", "Gyömrő", "Mende", "Maglód", "Pusztaszentistván",
        "Kóka", "Úri", "Tápiószecső", "Gyál", "Vecsés", "Pécel", "Ecser", "Üllő", "Nagykáta",
        "Szentmártonkáta", "Tóalmás", "Tápióság", "Gomba", "Péteri", "Monor", "Isaszeg", "Dány", "Zsámbok",
        "Tápióbicske", "Tápiószentmárton", "Bénye", "Káva", "Pánd",
    ]
};

const galleryImages = [
    "/images/first_before.jpg",
    "/images/first_after.jpg"
];
---

<Layout
    title="Gázszerelő &amp; Cirkó Javítás | Sülysáp, Gyömrő, Monor | Laczkó Gázszervíz"
    description="Gázcirkók, kazánok és bojlerek szakszerű javítása, karbantartása és cseréje több mint 40 év tapasztalattal. Kiszállás Sülysáp, Gyömrő és környékén. Hívjon bizalommal!"
>

    <header class="hero-section hero-pattern fade-in-up">
        <div class="hero-gradient-overlay"></div>
        <div class="container hero-container relative z-10">
            <div class="hero-content">
                <div class="hero-badge">
                    <Icon name="lucide:badge-check" class="badge-icon" />
                    {t('hero.badge')}
                </div>
                
                <h1 class="hero-title">
                    {t('hero.title.1')} <br/>
                    <span class="text-primary">{t('hero.title.2')}</span>
                </h1>
                
                <p class="hero-subtitle">
                    {t('hero.subtitle')}
                </p>
                
                <div class="hero-tags">
                    <span class="hero-tag"><Icon name="lucide:check-circle" class="tag-icon" /> {t('hero.tags.1')}</span>
                    <span class="hero-tag"><Icon name="lucide:check-circle" class="tag-icon" /> {t('hero.tags.2')}</span>
                    <span class="hero-tag"><Icon name="lucide:check-circle" class="tag-icon" /> {t('hero.tags.3')}</span>
                    <span class="hero-tag"><Icon name="lucide:check-circle" class="tag-icon" /> {t('hero.tags.4')}</span>
                </div>
                
                <div class="hero-actions">
                    <a class="btn-primary hero-btn-primary" href="/contact">
                        {t('hero.cta.primary')}
                    </a>
                    <a class="btn-outline hero-btn-outline" href="/services">
                        {t('hero.cta.secondary')}
                    </a>
                </div>
            </div>
        </div>
    </header>

    <section class="trust-banner container fade-in-up">
        <div class="trust-card">
            <div class="trust-glow-1"></div>
            <div class="trust-glow-2"></div>
            
            <div class="trust-grid relative z-10">
                <div class="trust-text-content">
                    <span class="trust-badge">{t('promo.badge')}</span>
                    <h2 class="trust-title">{t('promo.title')}</h2>
                    <p class="trust-subtitle">{t('promo.subtitle')}</p>
                    <ul class="trust-list">
                        <li class="trust-list-item"><Icon name="lucide:check" class="list-icon" /> {t('promo.list.1')}</li>
                        <li class="trust-list-item"><Icon name="lucide:check" class="list-icon" /> {t('promo.list.2')}</li>
                        <li class="trust-list-item"><Icon name="lucide:check" class="list-icon" /> {t('promo.list.3')}</li>
                    </ul>
                </div>
                
                <div class="trust-action">
                    <a class="trust-btn" href={`tel:${t('contact.phone')}`}>
                        <Icon name="lucide:phone-call" class="btn-icon" />
                        {t('promo.cta')}
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="features-row fade-in-up">
        <div class="container">
            <div class="features-grid">
                <div class="feature-item">
                    <div class="feature-icon-wrapper">
                        <Icon name="lucide:award" />
                    </div>
                    <div>
                        <h3 class="feature-title">{t('trust.1.title')}</h3>
                        <p class="feature-desc">{t('trust.1.text')}</p>
                    </div>
                </div>
                
                <div class="feature-item">
                    <div class="feature-icon-wrapper">
                        <Icon name="lucide:shield-check" />
                    </div>
                    <div>
                        <h3 class="feature-title">{t('trust.2.title')}</h3>
                        <p class="feature-desc">{t('trust.2.text')}</p>
                    </div>
                </div>
                
                <div class="feature-item">
                    <div class="feature-icon-wrapper">
                        <Icon name="lucide:sparkles" />
                    </div>
                    <div>
                        <h3 class="feature-title">{t('trust.3.title')}</h3>
                        <p class="feature-desc">{t('trust.3.text')}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="brands-section py-20 bg-background-light fade-in-up">
        <div class="container text-center">
            <h2 class="section-title">{t('marquee.brands.title')}</h2>
            <p class="section-subtitle">{t('marquee.brands.subtitle')}</p>
            
            <div class="brands-flex">
                {brands.map(brand => (
                    <div class="brand-chip">
                        <Icon name="lucide:check-circle" class="brand-check" />
                        <span class="brand-name">{brand}</span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="services-section bg-slate-50 py-20 fade-in-up">
        <div class="container">
            <div class="section-header text-center mb-16">
                <h2 class="section-title">{t('feature.title')}</h2>
                <p class="section-subtitle">{t('feature.subtitle')}</p>
            </div>
            
            <div class="services-grid">
                <div class="service-card group">
                    <div class="service-icon-wrapper blue">
                        <Icon name="lucide:wrench" class="service-icon" />
                    </div>
                    <h3 class="service-title">{t('feature.1.title')}</h3>
                    <p class="service-desc">{t('feature.1.text')}</p>
                </div>
                
                <div class="service-card group">
                    <div class="service-icon-wrapper orange">
                        <Icon name="lucide:flame" class="service-icon" />
                    </div>
                    <h3 class="service-title">{t('feature.2.title')}</h3>
                    <p class="service-desc">{t('feature.2.text')}</p>
                </div>
                
                <div class="service-card group">
                    <div class="service-icon-wrapper green">
                        <Icon name="lucide:package" class="service-icon" />
                    </div>
                    <h3 class="service-title">{t('feature.3.title')}</h3>
                    <p class="service-desc">{t('feature.3.text')}</p>
                </div>
            </div>
        </div>
    </section>

    <section class="service-area-section py-20 bg-background-light fade-in-up">
        <div class="container">
            <div class="section-header text-center mb-12">
                <h2 class="section-title">{t('map.title')}</h2>
                <p class="section-subtitle">{t('map.subtitle')}</p>
            </div>

            <div class="map-card">
                <div class="map-grid">
                    <div class="map-visual">
                        <div class="map-placeholder">
                            <InteractiveMap servicedCities={locations.pestCounty} />
                        </div>
                    </div>
                    
                    <div class="map-content">
                        <div class="map-content-header">
                            <Icon name="lucide:map" class="map-icon" />
                            <h3 class="map-content-title">{t('map.list.title')}</h3>
                        </div>
                        
                        <div class="locations-grid">
                            <ul class="locations-list">
                                {locations.pestCounty.slice(0, Math.ceil(locations.pestCounty.length / 2)).map(city => (
                                    <li class="location-item"><span class="location-dot"></span>{city}</li>
                                ))}
                            </ul>
                            <ul class="locations-list">
                                {locations.pestCounty.slice(Math.ceil(locations.pestCounty.length / 2)).map(city => (
                                    <li class="location-item"><span class="location-dot"></span>{city}</li>
                                ))}
                            </ul>
                        </div>
                        
                        <div class="callout-box">
                            <p class="callout-text">{t('map.callout')}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="gallery-section py-20 bg-slate-50 fade-in-up">
        <div class="container">
            <h2 class="section-title text-center mb-12">{t('gallery.title')}</h2>
            
            <div class="gallery-grid">
                {galleryImages.map((img, index) => (
                    <div class="gallery-card group">
                        <img
                            src={img}
                            alt=""
                            class="gallery-bg-blur"
                            aria-hidden="true"
                        />
                        <img
                            src={img}
                            alt={`${t('feature.1.title')} - ${index === 0 ? t('gallery.label.before') : t('gallery.label.after')}`}
                            class="gallery-img"
                            loading="lazy"
                            decoding="async"
                            width="640"
                            height="400"
                        />
                    </div>
                ))}
            </div>
        </div>
    </section>
</Layout>

<style lang="scss">
    .hero-section {
        position: relative;
        overflow: hidden;
        padding-top: 5rem;
        padding-bottom: 6rem;
        
        &.hero-pattern {
            background-color: var(--surface-light);
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ea580c' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
    }

    .hero-gradient-overlay {
        position: absolute;
        inset: 0;
        z-index: 0;
        background: linear-gradient(to bottom, transparent, var(--background-light));
        pointer-events: none;
        
        .dark & {
            background: linear-gradient(to bottom, transparent, var(--background-dark));
        }
    }

    .hero-container {
        position: relative;
        z-index: 10;
    }

    .hero-content {
        text-align: center;
        max-width: 56rem;
        margin: 0 auto;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.375rem 1rem;
        border-radius: var(--radius-full);
        background-color: #ffedd5;
        color: var(--primary);
        font-weight: 500;
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
        border: 1px solid #fed7aa;
        
        .dark & {
            background-color: rgba(124, 45, 18, 0.3);
            border-color: #9a3412;
        }

        .badge-icon {
            font-size: 0.875rem;
            margin-right: 0.5rem;
        }
    }

    .hero-title {
        font-size: 2.25rem;
        line-height: 1.1;
        letter-spacing: -0.025em;
        margin-bottom: 1.5rem;
        color: var(--slate-900);
        
        @media (min-width: 768px) {
            font-size: 3.75rem;
        }
    }

    .hero-subtitle {
        margin-top: 1rem;
        font-size: 1.25rem;
        color: var(--slate-600);
        max-width: 42rem;
        margin-left: auto;
        margin-right: auto;
    }

    .hero-tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
        margin-top: 2rem;
    }

    .hero-tag {
        display: flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background-color: var(--white);
        border-radius: var(--radius-lg);
        font-size: 0.875rem;
        color: var(--slate-600);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--slate-200);
        
        .dark & {
            background-color: var(--surface-dark);
            color: var(--slate-300);
            border-color: var(--slate-700);
        }

        .tag-icon {
            color: var(--primary);
            font-size: 1rem;
            margin-right: 0.5rem;
        }
    }

    .hero-actions {
        margin-top: 2.5rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .trust-banner {
        margin-top: -2.5rem;
        position: relative;
        z-index: 20;
    }

    .trust-card {
        background-color: var(--primary);
        border-radius: var(--radius-2xl);
        padding: 2rem;
        box-shadow: var(--shadow-2xl);
        position: relative;
        overflow: hidden;
        
        @media (min-width: 768px) {
            padding: 3rem;
        }
    }

    .trust-glow-1 {
        position: absolute;
        top: -6rem;
        right: -6rem;
        width: 16rem;
        height: 16rem;
        background-color: #f97316;
        border-radius: var(--radius-full);
        opacity: 0.5;
        filter: blur(48px);
        z-index: 1;
    }

    .trust-glow-2 {
        position: absolute;
        bottom: -6rem;
        left: -6rem;
        width: 16rem;
        height: 16rem;
        background-color: #c2410c;
        border-radius: var(--radius-full);
        opacity: 0.5;
        filter: blur(48px);
        z-index: 1;
    }

    .trust-grid {
        display: grid;
        gap: 2rem;
        align-items: center;
        position: relative;
        z-index: 10;
        
        @media (min-width: 768px) {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .trust-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-md);
        background-color: rgba(0, 0, 0, 0.2);
        color: var(--white);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
        text-transform: uppercase;
    }

    .trust-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--white);
        margin-bottom: 1rem;
    }

    .trust-subtitle {
        color: #fff7ed;
        margin-bottom: 1.5rem;
        font-size: 1.125rem;
    }

    .trust-list {
        list-style: none;
        padding: 0;
        margin: 0;
        color: rgba(255, 255, 255, 0.9);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        
        .trust-list-item {
            display: flex;
            align-items: center;
            font-size: 1rem;
            
            .list-icon {
                margin-right: 0.5rem;
                font-size: 1.25rem;
            }
        }
    }

    .trust-action {
        display: flex;
        justify-content: center;
        
        @media (min-width: 768px) {
            justify-content: flex-end;
        }
    }

    .trust-btn {
        display: inline-flex;
        align-items: center;
        padding: 1rem 2rem;
        background-color: var(--white);
        color: var(--primary);
        border-radius: var(--radius-xl);
        font-weight: 700;
        box-shadow: var(--shadow-lg);
        text-decoration: none;
        transition: transform 0.3s, background-color 0.3s;
        
        &:hover {
            background-color: #f9fafb;
            transform: scale(1.05);
        }

        .btn-icon {
            margin-right: 0.5rem;
        }
    }

    .features-row {
        background-color: var(--slate-900);
        padding: 3rem 0;
        margin-top: 4rem;
        
        .dark & {
            background-color: var(--black);
        }
    }

    .features-grid {
        display: grid;
        gap: 2rem;
        
        @media (min-width: 768px) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .feature-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem;
        
        .feature-icon-wrapper {
            flex-shrink: 0;
            width: 3rem;
            height: 3rem;
            border-radius: var(--radius-full);
            background-color: var(--slate-800);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
        }
        
        .feature-title {
            color: var(--white);
            font-size: 1.125rem;
            margin-bottom: 0.25rem;
        }
        
        .feature-desc {
            color: var(--slate-400);
            font-size: 0.875rem;
            line-height: 1.625;
            margin: 0;
        }
    }

    .py-20 {
        padding-top: 5rem;
        padding-bottom: 5rem;
    }

    .bg-background-light {
        background-color: var(--background-light);
        .dark & {
            background-color: var(--background-dark);
        }
    }

    .bg-slate-50 {
        background-color: var(--slate-50);
        .dark & {
            background-color: #202023;
        }
    }

    .section-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: var(--slate-900);
        margin-bottom: 0.75rem;
        
        .dark & {
            color: var(--white);
        }
    }

    .section-subtitle {
        color: var(--slate-600);
        margin-bottom: 2.5rem;
        
        .dark & {
            color: var(--slate-400);
        }
    }

    .text-center {
        text-align: center;
    }

    .mb-12 {
        margin-bottom: 3rem;
    }

    .mb-16 {
        margin-bottom: 4rem;
    }

    .brands-flex {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1.5rem;
    }

    .brand-chip {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background-color: var(--white);
        border-radius: var(--radius-full);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--slate-100);
        transition: box-shadow 0.3s;
        
        &:hover {
            box-shadow: var(--shadow-md);
        }
        
        .dark & {
            background-color: var(--surface-dark);
            border-color: var(--slate-800);
        }

        .brand-check {
            font-size: 0.875rem;
            
            &:nth-child(even) { color: #16a34a; }
            &:nth-child(odd) { color: #ea580c; }
        }

        .brand-name {
            font-weight: 600;
            color: var(--slate-700);
            
            .dark & {
                color: var(--slate-200);
            }
        }
    }

    .services-grid {
        display: grid;
        gap: 2rem;
        
        @media (min-width: 768px) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .service-card {
        background-color: var(--white);
        border-radius: var(--radius-2xl);
        padding: 2rem;
        box-shadow: var(--shadow-soft);
        border: 1px solid var(--slate-100);
        transition: box-shadow 0.3s;
        
        &:hover {
            box-shadow: var(--shadow-hover);
        }
        
        .dark & {
            background-color: var(--surface-dark);
            border-color: var(--slate-700);
        }
        
        .service-icon-wrapper {
            width: 3.5rem;
            height: 3.5rem;
            border-radius: var(--radius-xl);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            transition: background-color 0.3s;
            
            &.blue {
                background-color: #eff6ff;
                .dark & { background-color: rgba(30, 58, 138, 0.3); }
                .service-icon { color: #2563eb; }
            }
            
            &.orange {
                background-color: #fff7ed;
                .dark & { background-color: rgba(124, 45, 18, 0.3); }
                .service-icon { color: #ea580c; }
            }
            
            &.green {
                background-color: #f0fdf4;
                .dark & { background-color: rgba(20, 83, 45, 0.3); }
                .service-icon { color: #16a34a; }
            }
        }
        
        &:hover {
            .service-icon-wrapper {
                background-color: rgba(var(--primary-rgb), 0.1);
            }
            .service-icon {
                color: var(--primary);
            }
        }

        .service-icon {
            font-size: 1.875rem;
            transition: color 0.3s;
        }

        .service-title {
            font-size: 1.25rem;
            color: var(--slate-900);
            margin-bottom: 0.75rem;
            
            .dark & {
                color: var(--white);
            }
        }

        .service-desc {
            color: var(--slate-600);
            font-size: 0.875rem;
            line-height: 1.625;
            margin: 0;
            
            .dark & {
                color: var(--slate-400);
            }
        }
    }

    .map-card {
        background-color: var(--white);
        border-radius: var(--radius-3xl);
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--slate-100);
        overflow: hidden;
        
        .dark & {
            background-color: var(--surface-dark);
            border-color: var(--slate-700);
        }
    }

    .map-grid {
        display: grid;
        grid-template-columns: 1fr;
        
        @media (min-width: 768px) {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .map-visual {
        background-color: var(--slate-50);
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        min-height: 400px;
        
        .dark & {
            background-color: var(--slate-800);
        }
    }

    .map-placeholder {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;

        :global(.map-container) {
            width: 100%;
            height: 100%;
            position: absolute;
            inset: 0;
        }
    }

    .map-content {
        padding: 2rem;
        
        @media (min-width: 768px) {
            padding: 3rem;
        }
    }

    .map-content-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;

        .map-icon {
            color: var(--primary);
            font-size: 1.5rem;
        }

        .map-content-title {
            font-size: 1.25rem;
            color: var(--slate-900);
            margin: 0;
            
            .dark & {
                color: var(--white);
            }
        }
    }

    .locations-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        row-gap: 0.75rem;
    }

    .locations-list {
        list-style: none;
        padding: 0;
