---
import 'leaflet/dist/leaflet.css';

const { servicedCities = [] } = Astro.props;
---

<div id="service-map" class="map-container"></div>

<script>
    let mapObserver: IntersectionObserver | null = null;

    function setupMapObserver() {
        mapObserver?.disconnect();
        mapObserver = null;

        const mapContainer = document.getElementById('service-map');
        if (!mapContainer) return;

        mapObserver = new IntersectionObserver(async (entries, obs) => {
            if (entries[0].isIntersecting) {
                obs.disconnect();
                mapObserver = null;
                const { initMap } = await import('../lib/mapInit.ts');
                await initMap('service-map', 'service-map-data');
            }
        }, { rootMargin: '200px' });

        mapObserver.observe(mapContainer);
    }

    document.addEventListener('astro:before-preparation', () => {
        mapObserver?.disconnect();
        mapObserver = null;
    });

    document.addEventListener('astro:page-load', setupMapObserver);
</script>

<style is:global>
    .map-container {
        height: 100%;
        min-height: 400px;
        width: 100%;
        border-radius: 8px;
        background-color: #f8fafc !important;
        border: 1px solid var(--slate-200);
        box-shadow: var(--shadow-sm);
        z-index: 1;
    }

    .tooltip-serviced {
        background-color: #dd6b20 !important;
        color: white !important;
        border: none !important;
        border-radius: 4px !important;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 4px 8px !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
    }
    .tooltip-serviced::before {
        border-top-color: #dd6b20 !important;
    }

    .tooltip-unserviced {
        background-color: rgba(255, 255, 255, 0.95) !important;
        color: #64748b !important;
        border: 1px solid #cbd5e1 !important;
        border-radius: 4px !important;
        font-weight: 500;
        font-size: 0.85rem;
        padding: 4px 8px !important;
    }
    .tooltip-unserviced::before {
        border-top-color: #cbd5e1 !important;
    }

    .map-polygon-non-interactive {
        cursor: default !important;
        outline: none;
    }
</style>

<div
        id="service-map-data"
        style="display:none"
        data-cities={JSON.stringify(servicedCities)}
></div>