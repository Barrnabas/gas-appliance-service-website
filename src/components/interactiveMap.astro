---
import 'leaflet/dist/leaflet.css';

const { servicedCities = [] } = Astro.props;
---

<div id="service-map" class="map-container"></div>

<script>
    import L from 'leaflet';
    import { parseCities } from '../utils/mapUtils';

    document.addEventListener('astro:page-load', async () => {
        const mapContainer = document.getElementById('service-map');
        const dataContainer = document.getElementById('service-map-data');

        if (!mapContainer || !dataContainer) return;

        const servicedCities = parseCities(dataContainer.dataset.cities);

        if ((mapContainer as any)._leaflet_id) {
            (mapContainer as any)._leaflet_id = null;
        }

        const map = L.map('service-map', {
            zoomControl: true,
            attributionControl: false
        });

        try {
            const response = await fetch('/pest_borders.geojson');

            if (!response.ok) {
                console.error(`Error during loding the GeoJSON: ${response.status}`);
                map.setView([47.45, 19.53], 10);
                return;
            }

            const geojsonData = await response.json();

            const geojsonLayer = L.geoJSON(geojsonData, {
                filter: (feature) =>
                    feature.geometry.type === 'Polygon' || feature.geometry.type === 'MultiPolygon',

                style: (feature) => {
                    const cityName = feature?.properties?.name;
                    const isServiced = cityName && servicedCities.includes(cityName);
                    return {
                        color: "#ffffff",
                        weight: isServiced ? 2 : 1,
                        fillColor: isServiced ? "#dd6b20" : "#e2e8f0",
                        fillOpacity: isServiced ? 0.8 : 0.6
                    };
                },
                onEachFeature: (feature, layer) => {
                    const cityName = feature?.properties?.name;
                    if (cityName) {
                        const isServiced = servicedCities.includes(cityName);

                        layer.bindTooltip(cityName, {
                            direction: "top",
                            className: isServiced ? "tooltip-serviced" : "tooltip-unserviced"
                        });

                        layer.on({
                            mouseover: (e) => {
                                const l = e.target;
                                l.setStyle({
                                    weight: 3,
                                    color: isServiced ? '#c05621' : '#94a3b8'
                                });
                                l.bringToFront();
                            },
                            mouseout: (e) => geojsonLayer.resetStyle(e.target)
                        });
                    }
                }
            }).addTo(map);

            map.fitBounds(geojsonLayer.getBounds());
            const currentZoom = map.getZoom();
            map.setMaxBounds(geojsonLayer.getBounds());
            map.setMinZoom(currentZoom);
            map.setMaxZoom(currentZoom + 3);

        } catch (error) {
            console.error("Map error:", error);
            map.setView([47.45, 19.53], 10);
        }
    });
</script>

<style is:global>
    .map-container {
        height: 100%;
        min-height: 400px;
        width: 100%;
        border-radius: 8px;
        background-color: #f8fafc !important;
        border: 1px solid var(--gray-200);
        box-shadow: var(--shadow-sm);
        z-index: 1;
    }

    .tooltip-serviced {
        background-color: #dd6b20 !important;
        color: white !important;
        border: none !important;
        border-radius: 4px !important;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 4px 8px !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
    }
    .tooltip-serviced::before {
        border-top-color: #dd6b20 !important;
    }

    .tooltip-unserviced {
        background-color: rgba(255, 255, 255, 0.95) !important;
        color: #64748b !important;
        border: 1px solid #cbd5e1 !important;
        border-radius: 4px !important;
        font-weight: 500;
        font-size: 0.85rem;
        padding: 4px 8px !important;
    }
    .tooltip-unserviced::before {
        border-top-color: #cbd5e1 !important;
    }
</style>

<div
        id="service-map-data"
        style="display:none"
        data-cities={JSON.stringify(servicedCities)}
></div>