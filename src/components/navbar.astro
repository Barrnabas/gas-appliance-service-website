---
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

const t = useTranslations();

const navLinks = [
    { name: t('nav.home'), href: `/` },
    { name: t('nav.about'), href: `/about` },
    { name: t('nav.services'), href: `/services` },
    { name: t('nav.contact'), href: `/contact` },
];
---

<header class="navbar">
    <div class="container nav-container">
        <a href="/" class="logo">
            <Icon name="lucide:flame" class="logo-icon" />
            <span class="logo-text">Laczkó<span class="text-primary">Gázszerviz</span></span>
        </a>

        <nav class="desktop-nav">
            <div class="nav-links">
                {navLinks.map((link) => (
                        <a href={link.href} class="nav-link">{link.name}</a>
                ))}
            </div>
        </nav>

        <button class="mobile-menu-btn" id="menu-toggle" aria-label="Menu" aria-expanded="false">
            <Icon name="lucide:menu" size={28} />
        </button>
    </div>
</header>

<div class="mobile-nav-overlay" id="mobile-menu">
    <div class="mobile-nav-content">
        <button class="close-menu-btn" id="close-menu" aria-label="Close Menu">
            <Icon name="lucide:x" size={28} />
        </button>
        <nav class="mobile-nav-links">
            {navLinks.map((link) => (
                    <a href={link.href} class="mobile-nav-link">{link.name}</a>
            ))}
        </nav>
    </div>
</div>


<style lang="scss">
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(253, 251, 247, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--slate-200);
    transition: background-color 0.3s;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 5rem;
  }

  .logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;

    .logo-icon {
      color: var(--primary);
      font-size: 1.875rem;
    }

    .logo-text {
      font-weight: 700;
      font-size: 1.25rem;
      letter-spacing: -0.025em;
      color: var(--slate-900);
    }

    .text-primary {
      color: var(--primary);
    }
  }

  .desktop-nav {
    display: none;

    @media (min-width: 768px) {
      display: flex;
      gap: 2rem;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
    }

    .nav-link {
      text-decoration: none;
      color: var(--slate-600);
      font-weight: 500;
      transition: color 0.15s ease;

      &:hover {
        color: var(--primary);
      }
    }
  }

  .mobile-menu-btn {
    /* Removed the duplicate display: block */
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--slate-600);
    cursor: pointer;
    padding: 0.5rem;

    @media (min-width: 768px) {
      display: none;
    }

    svg {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  .mobile-nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background-color: rgba(0, 0, 0, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;

    &.active {
      opacity: 1;
      pointer-events: auto;

      .mobile-nav-content {
        transform: translateX(0);
        visibility: visible;
      }
    }
  }

  .mobile-nav-content {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 80%;
    max-width: 320px;
    background-color: var(--white);
    padding: 1.5rem;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    z-index: 101;
    visibility: hidden;
    border-left: 1px solid var(--slate-200);
    box-shadow: var(--shadow-2xl);
    /* Ensure the content box itself doesn't cause overflow */
    box-sizing: border-box;

    .close-menu-btn {
      position: absolute;
      top: 0.75rem;
      right: 0.625rem;
      background: transparent;
      border: none;
      color: var(--slate-500);
      cursor: pointer;
      padding: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-full);
      /* Target specific properties to prevent zoom/shift artifacts */
      transition: background-color 0.2s, color 0.2s;

      &:hover {
        background-color: var(--slate-100);
        color: var(--slate-900);
      }

      svg {
        width: 2rem;
        height: 2rem;
      }
    }

    .mobile-nav-links {
      display: flex;
      flex-direction: column;
      gap: 0.5rem; /* Reduced gap slightly so buttons don't feel too detached */
      align-items: stretch; /* Forces children to stretch to container width naturally */
      justify-content: center;
      flex-grow: 1;
      padding-bottom: 5rem;
      width: 100%;
    }

    .mobile-nav-link {
      display: block;
      text-decoration: none;
      font-size: 1.5rem; /* Slightly reduced for better mobile fit */
      font-weight: 700;
      color: var(--slate-900);
      padding: 1rem; /* Reduced horizontal padding */
      border-radius: var(--radius-xl);
      /* Target specific properties to prevent the "growing" bug */
      transition: background-color 0.2s, color 0.2s;
      width: 100%;
      box-sizing: border-box; /* Crucial: stops padding from adding to the 100% width */
      text-align: center;

      &:hover {
        background-color: var(--slate-50);
        color: var(--primary);
      }
    }
  }
</style>

<script>
    let menuController: AbortController | null = null;

    function setupMenu() {
        menuController?.abort();
        menuController = new AbortController();
        const { signal } = menuController;

        const menuToggle = document.getElementById('menu-toggle');
        const closeMenuBtn = document.getElementById('close-menu');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-nav-link');

        function openMenu() {
            if (mobileMenu && menuToggle) {
                mobileMenu.classList.add('active');
                menuToggle.setAttribute('aria-expanded', 'true');
                
                const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;

                if (scrollbarWidth > 0) {
                    document.body.style.paddingRight = `${scrollbarWidth}px`;
                }
                document.body.style.overflow = 'hidden';
            }
        }

        function closeMenu() {
            if (mobileMenu && menuToggle) {
                mobileMenu.classList.remove('active');
                menuToggle.setAttribute('aria-expanded', 'false');

                document.body.style.overflow = '';
                document.body.style.paddingRight = '';
            }
        }

        menuToggle?.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = mobileMenu?.classList.contains('active');
            if (isOpen) closeMenu();
            else openMenu();
        }, { signal });

        closeMenuBtn?.addEventListener('click', closeMenu, { signal });

        mobileMenu?.addEventListener('click', (e) => {
            if (e.target === mobileMenu) {
                closeMenu();
            }
        }, { signal });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mobileMenu?.classList.contains('active')) {
                closeMenu();
            }
        }, { signal });

        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                setTimeout(closeMenu, 150);
            }, { signal });
        });

        document.addEventListener('astro:before-preparation', closeMenu, { once: true, signal });
    }

    document.addEventListener('astro:page-load', setupMenu);
</script>

