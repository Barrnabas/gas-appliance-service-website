---
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

const t = useTranslations();

const navLinks = [
    { name: t('nav.home'), href: `/` },
    { name: t('nav.about'), href: `/about` },
    { name: t('nav.services'), href: `/services` },
    { name: t('nav.contact'), href: `/contact` },
];
---

<header class="navbar">
    <div class="container nav-container">
        <a href="/" class="logo">
            <Icon name="lucide:flame" class="logo-icon" />
            <span class="logo-text">Laczkó<span class="text-primary">Gázszerviz</span></span>
        </a>

        <nav class="desktop-nav">
            <div class="nav-links">
                {navLinks.map((link) => (
                        <a href={link.href} class="nav-link">{link.name}</a>
                ))}
            </div>
        </nav>

        <button class="mobile-menu-btn" id="menu-toggle" aria-label="Menu" aria-expanded="false">
            <Icon name="lucide:menu" />
        </button>

        <div class="mobile-nav-overlay" id="mobile-menu">
            <div class="mobile-nav-content">
                <button class="close-menu-btn" id="close-menu" aria-label="Close Menu">
                    <Icon name="lucide:x" />
                </button>
                <nav class="mobile-nav-links">
                    {navLinks.map((link) => (
                            <a href={link.href} class="mobile-nav-link">{link.name}</a>
                    ))}
                </nav>
            </div>
        </div>
    </div>
</header>

<style lang="scss">
    .navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background-color: rgba(253, 251, 247, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--slate-200);
        transition: background-color 0.3s;

        .dark & {
            background-color: rgba(24, 24, 27, 0.9);
            border-bottom-color: var(--slate-800);
        }
    }

    .nav-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 5rem;
    }

    .logo {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;

        .logo-icon {
            color: var(--primary);
            font-size: 1.875rem;
        }

        .logo-text {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.025em;
            color: var(--slate-900);
            
            .dark & {
                color: var(--white);
            }
        }

        .text-primary {
            color: var(--primary);
        }
    }

    .desktop-nav {
        display: none;
        
        @media (min-width: 768px) {
            display: flex;
            gap: 2rem;
        }
        
        .nav-links {
            display: flex;
            gap: 2rem;
        }

        .nav-link {
            text-decoration: none;
            color: var(--slate-600);
            font-weight: 500;
            transition: color 0.15s ease;

            .dark & {
                color: var(--slate-300);
            }

            &:hover {
                color: var(--primary);
                .dark & {
                    color: var(--primary);
                }
            }
        }
    }

    .mobile-menu-btn {
        display: block;
        background: transparent;
        border: none;
        color: var(--slate-600);
        cursor: pointer;
        padding: 0.5rem;
        
        .dark & {
            color: var(--slate-300);
        }

        @media (min-width: 768px) {
            display: none;
        }
        
        span {
            font-size: 1.75rem;
        }
    }

    .mobile-nav-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        background-color: rgba(0, 0, 0, 0.5);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;

        &.active {
            opacity: 1;
            pointer-events: auto;

            .mobile-nav-content {
                transform: translateX(0);
            }
        }
    }

    .mobile-nav-content {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        width: 80%;
        max-width: 320px;
        background-color: var(--background-light);
        padding: 2rem 1.5rem;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-2xl);

        .dark & {
            background-color: var(--background-dark);
            border-left: 1px solid var(--slate-800);
        }

        .close-menu-btn {
            align-self: flex-end;
            background: transparent;
            border: none;
            color: var(--slate-500);
            cursor: pointer;
            padding: 0.5rem;
            margin-bottom: 2rem;

            &:hover {
                color: var(--slate-900);
                .dark & {
                    color: var(--white);
                }
            }
        }

        .mobile-nav-links {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .mobile-nav-link {
            text-decoration: none;
            font-size: 1.25rem;
            font-weight: 500;
            color: var(--slate-700);
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--slate-200);

            .dark & {
                color: var(--slate-200);
                border-bottom-color: var(--slate-800);
            }

            &:hover {
                color: var(--primary);
                .dark & {
                    color: var(--primary);
                }
            }
        }
    }
</style>

<script>
    let menuController: AbortController | null = null;

    function setupMenu() {
        menuController?.abort();
        menuController = new AbortController();
        const { signal } = menuController;

        const menuToggle = document.getElementById('menu-toggle');
        const closeMenuBtn = document.getElementById('close-menu');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-nav-link');

        function openMenu() {
            if (mobileMenu && menuToggle) {
                mobileMenu.classList.add('active');
                menuToggle.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';
            }
        }

        function closeMenu() {
            if (mobileMenu && menuToggle) {
                mobileMenu.classList.remove('active');
                menuToggle.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
            }
        }

        menuToggle?.addEventListener('click', openMenu, { signal });
        closeMenuBtn?.addEventListener('click', closeMenu, { signal });

        mobileMenu?.addEventListener('click', (e) => {
            if (e.target === mobileMenu) closeMenu();
        }, { signal });

        mobileLinks.forEach(link => {
            link.addEventListener('click', closeMenu, { signal });
        });
    }

    document.addEventListener('astro:before-preparation', () => menuController?.abort());
    document.addEventListener('astro:page-load', setupMenu);
</script>
