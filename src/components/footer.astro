---
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

const t = useTranslations();
const year = new Date().getFullYear();
---

<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-brand">
                <div class="brand">
                <Icon name="lucide:flame" class="brand-icon" />
                <span class="brand-text">Laczkó<span class="text-primary">Gázszerviz</span></span>
            </div>
                <p class="brand-slogan">{t('footer.slogan')}</p>
            </div>

            <div class="footer-nav">
                <h4 class="nav-title">Navigáció</h4>
                <ul class="nav-list">
                    <li><a href="/" class="nav-link">{t('nav.home')}</a></li>
                    <li><a href="/about" class="nav-link">{t('nav.about')}</a></li>
                    <li><a href="/services" class="nav-link">{t('nav.services')}</a></li>
                    <li><a href="/contact" class="nav-link">{t('nav.contact')}</a></li>
                </ul>
            </div>

            <div class="footer-contact">
                <h4 class="nav-title">Elérhetőség</h4>
                <ul class="contact-list">
                    <li class="contact-item">
                        <Icon name="lucide:phone" class="contact-icon" />
                        <a href={`tel:${t('contact.phone')}`} class="contact-link">{t('contact.phone.display')}</a>
                    </li>
                    <li class="contact-item">
                        <Icon name="lucide:mail" class="contact-icon" />
                        <a href={`mailto:${t('contact.info.email.address')}`} class="contact-link">{t('contact.info.email.address')}</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="bottom-bar">
            <p class="copyright">&copy; {year} Laczkó Gázszerviz. Minden jog fenntartva.</p>

            <div class="legal-links">
                <a href="/legal" class="legal-link">{t('footer.legal.imprint')}</a>
                <a href="/legal" class="legal-link">{t('footer.legal.terms')}</a>
            </div>
        </div>
    </div>
</footer>

<style lang="scss">
    .footer {
        background-color: var(--slate-900);
        color: var(--slate-300);
        padding-top: 4rem;
        padding-bottom: 2rem;
        border-top: 1px solid var(--slate-800);
        margin-top: 5rem;
        
        .dark & {
            background-color: var(--black);
        }
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        margin-bottom: 3rem;

        @media (min-width: 768px) {
            grid-template-columns: repeat(2, 1fr);
        }

        @media (min-width: 1024px) {
            grid-template-columns: 2fr 1fr 1fr;
        }
    }

    .brand-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;

        .brand-icon {
            color: var(--primary);
            font-size: 1.5rem;
        }

        .brand-name {
            font-weight: 700;
            font-size: 1.25rem;
            color: var(--white);
            
            .text-primary {
                color: var(--primary);
            }
        }
    }

    .brand-slogan {
        color: var(--slate-400);
        max-width: 24rem;
        margin: 0;
        font-size: 1rem;
        line-height: 1.5;
    }

    .nav-title {
        color: var(--white);
        font-weight: 700;
        margin-bottom: 1rem;
        text-transform: uppercase;
        font-size: 0.875rem;
        letter-spacing: 0.05em;
    }

    .nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;    

        .nav-link {
            color: var(--slate-300);
            text-decoration: none;
            transition: color 0.3s;

            &:hover {
                color: var(--primary);
            }
        }
    }

    .contact-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;

        .contact-item {
            display: flex;
            align-items: flex-start;
        }

        .contact-icon {
            color: var(--primary);
            font-size: 0.875rem;
            margin-right: 0.5rem;
            margin-top: 0.25rem;
        }

        .contact-link {
            color: var(--slate-300);
            text-decoration: none;
            transition: color 0.3s;

            &:hover {
                color: var(--white);
            }
        }
    }

    .bottom-bar {
        border-top: 1px solid var(--slate-800);
        padding-top: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        font-size: 0.875rem;
        color: var(--slate-500);

        @media (min-width: 768px) {
            flex-direction: row;
        }

        .copyright {
            margin: 0;
            margin-bottom: 1rem;

            @media (min-width: 768px) {
                margin-bottom: 0;
            }
        }

        .legal-links {
            display: flex;
            gap: 1.5rem;

            .legal-link {
                color: var(--slate-500);
                text-decoration: none;
                transition: color 0.3s;

                &:hover {
                    color: var(--white);
                }
            }
        }
    }
</style>