---
import { useTranslations } from '../i18n/utils';

const t = useTranslations();
const year = new Date().getFullYear();
---

<footer>
    <div class="container footer-content">
        <div class="brand">
            <a href="/" class="logo">
                🔥 Laczkó<span class="text-primary">Gázszervíz</span>
            </a>
            <p>{t('footer.slogan')}</p>
        </div>

        <div class="contact-info">
            <p><strong>Telefon:</strong> <a href={`tel:${t('contact.phone')}`}>{t('contact.phone.display')}</a></p>
            <p><strong>Email:</strong> <a href={`mailto:${t('contact.info.email.address')}`}>{t('contact.info.email.address')}</a></p>
        </div>
    </div>

    <div class="bottom-bar container">
        <p>&copy; {year} Laczkó Gázszervíz. {t('footer.rights')}</p>

        <div class="legal-links">
            <a href="/legal">{t('footer.legal.imprint')}</a>
            <span class="divider">•</span>
            <a href="/legal">{t('footer.legal.terms')}</a>
        </div>
    </div>
</footer>

<style lang="scss">
  footer {
    background-color: var(--dark);
    color: var(--white);
    padding: 4rem 0 1.5rem;
    margin-top: 6rem;

    .footer-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      padding-bottom: 2.5rem;
      margin-bottom: 1.5rem;

      @media (max-width: 768px) {
        flex-direction: column;
        gap: 2rem;
        text-align: center;
      }
    }

    .brand {
      .logo {
        font-family: 'Poppins', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--white);
        text-decoration: none;
        display: block;
        margin-bottom: 0.5rem;

        .text-primary { color: var(--primary); }
      }
      p { color: var(--text-muted); margin: 0; }
    }

    .contact-info {
      text-align: right;

      p { margin: 0.2rem 0; color: var(--gray-200); }

      a {
        color: var(--white);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s;

        &:hover { color: var(--primary); }
      }

      @media (max-width: 768px) {
        text-align: center;
      }
    }

    .bottom-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--text-muted);
      font-size: 0.85rem;

      p { margin: 0; }

      .legal-links {
        display: flex;
        gap: 0.8rem;
        align-items: center;

        a {
          color: var(--text-muted);
          text-decoration: none;
          transition: color 0.3s;
          &:hover { color: var(--white); }
        }

        .divider {
          opacity: 0.3;
        }
      }

      @media (max-width: 768px) {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
      }
    }
  }
</style>